// Custom patterns for LED matrix
byte smiley[8] = {
  B00111100,
  B01000010,
  B10100101,
  B10000001,
  B10100101,
  B10011001,
  B01000010,
  B00111100#include <SPI.h>
#include <MFRC522.h>
#include <LedControl.h>


// RFID Pins
#define SS_PIN 10
#define RST_PIN 7


// MAX7219 LED Matrix Pins
#define DIN_PIN 2
#define CS_PIN 3
#define CLK_PIN 4


MFRC522 rfid(SS_PIN, RST_PIN);
LedControl lc = LedControl(DIN_PIN, CLK_PIN, CS_PIN, 1); // 1 matrix




};


byte checkMark[8] = {
  B00000000,
  B00000001,
  B00000011,
  B00000110,
  B01001100,
  B11111000,
  B01110000,
  B00100000
};


byte heart[8] = {
  B00000000,
