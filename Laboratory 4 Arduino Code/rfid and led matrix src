void setup() {
  Serial.begin(9600);
  while (!Serial);
 
  Serial.println("Starting RFID Reader with LED Matrix...");
 
  // Initialize SPI
  SPI.begin();
 
  // Initialize LED Matrix first
  lc.shutdown(0, false);      // Wake up MAX7219
  lc.setIntensity(0, 5);      // Reduced brightness to avoid power issues
  lc.clearDisplay(0);         // Clear display
  delay(100);                 // Small delay after LED init
 
  // Initialize RFID after LED matrix
  rfid.PCD_Init();
  delay(100);                 // Small delay after RFID init
 
  // Check if RFID module is connected
  byte version = rfid.PCD_ReadRegister(rfid.VersionReg);
  if (version == 0x00 || version == 0xFF) {
    Serial.println("ERROR: RFID module not detected! Check wiring.");
    displayPattern(cross);    // Show error pattern
    while(1);
  } else {
    Serial.print("RFID Module detected. Version: 0x");
    Serial.println(version, HEX);
    displayPattern(smiley);   // Show ready pattern
    delay(2000);
    lc.clearDisplay(0);
  }
 
  Serial.println("Place an RFID tag near the reader...");
  showWaitingAnimation();
}


void loop() {
  // Reduced animation frequency to avoid SPI conflicts
  static unsigned long lastAnimation = 0;
  static int animStep = 0;
  static unsigned long lastRFIDCheck = 0;
 
  // Update animation less frequently
  if (millis() - lastAnimation > 1000) { // Changed from 500 to 1000ms
    showScanningDot(animStep % 32); // Changed from 8 to 32 for smoother animation
    animStep++;
    lastAnimation = millis();
  }
 
  // Check RFID less frequently to avoid conflicts
  if (millis() - lastRFIDCheck > 100) { // Check every 100ms
    lastRFIDCheck = millis();
   
    // Add debug output
    Serial.print(".");  // Show that we're checking
   
    // Check for RFID card
    if (rfid.PICC_IsNewCardPresent()) {
      Serial.println("\nCard present detected!");
     
      if (rfid.PICC_ReadCardSerial()) {
        Serial.println("Card read successfully!");
       
        // Stop animations during card reading
        lc.clearDisplay(0);
        displayPattern(checkMark);
       
        Serial.println("*** RFID Tag Detected ***");
       
        MFRC522::PICC_Type piccType = rfid.PICC_GetType(rfid.uid.sak);
       
        Serial.print("Card Type: ");
        Serial.println(rfid.PICC_GetTypeName(piccType));
       
        Serial.print("RFID Tag UID:");
        printHex(rfid.uid.uidByte, rfid.uid.size);
        Serial.println();
       
        // Display UID on matrix
        delay(1000);
        displayUIDPattern();
       
        Serial.println("*** End ***");
        Serial.println();
       
        delay(3000); // Show pattern for 3 seconds
        lc.clearDisplay(0);
       
        rfid.PICC_HaltA();
        rfid.PCD_StopCrypto1();
       
        // Reset animation
        animStep = 0;
      } else {
        Serial.println("\nFailed to read card serial");
      }
    }
  }
}


void displayPattern(byte pattern[]) {
  for (int row = 0; row < 8; row++) {
    lc.setRow(0, row, pattern[row]);
  }
  delayMicroseconds(100); // Small delay between SPI operations
}


void showWaitingAnimation() {
  // Show a brief startup animation
  for (int i = 0; i < 8; i++) {
    lc.setRow(0, i, B11111111);
    delay(100);
  }
  delay(200);
  lc.clearDisplay(0);
}


void showScanningDot(int position) {
  // Don't clear display every time - just update the dot
  static int lastPos = -1;
 
  // Clear previous dot
  if (lastPos >= 0) {
    if (lastPos < 8) {
      lc.setLed(0, 0, lastPos, false);
    } else if (lastPos < 16) {
      lc.setLed(0, lastPos - 8, 7, false);
    } else if (lastPos < 24) {
      lc.setLed(0, 7, 7 - (lastPos - 16), false);
    } else {
      lc.setLed(0, 7 - (lastPos - 24), 0, false);
    }
  }
 
  // Set new dot position
  position = position % 32;
  if (position < 8) {
    lc.setLed(0, 0, position, true);
  } else if (position < 16) {
    lc.setLed(0, position - 8, 7, true);
  } else if (position < 24) {
    lc.setLed(0, 7, 7 - (position - 16), true);
  } else {
    lc.setLed(0, 7 - (position - 24), 0, true);
  }
 
  lastPos = position;
  delayMicroseconds(100); // Small delay after LED operation
}


void displayUIDPattern() {
  lc.clearDisplay(0);
 
  // Create a unique pattern based on UID
  byte lastByte = rfid.uid.uidByte[rfid.uid.size - 1];
 
  for (int i = 0; i < 8; i++) {
    if (lastByte & (1 << i)) {
      lc.setLed(0, i, i, true);
      lc.setLed(0, 7-i, 7-i, true);
    }
  }
  delayMicroseconds(100);
}


void printHex(byte *buffer, byte bufferSize) {
  for (byte i = 0; i < bufferSize; i++) {
    Serial.print(buffer[i] < 0x10 ? " 0" : " ");
    Serial.print(buffer[i], HEX);
  }
}